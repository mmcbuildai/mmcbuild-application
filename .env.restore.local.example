# .env.restore.local.example — mmc-application (the MMC Build app)
# Generated from byok.config.json.
#
# HOW TO USE
#   1. Copy this to .env.restore.local
#   2. Replace every `...` with your real value (lines still ending in `...` are SKIPPED, so partial fills re-run safely)
#   3. node scripts/vercel-env-restore.mjs            # dry-run, shows what will push
#   4. node scripts/vercel-env-restore.mjs --apply    # pushes to Production + Preview + Development
#   5. DELETE .env.restore.local afterwards — it holds plaintext secrets.
#
# [R] = required to run the app   [O] = optional / feature-gated
# Keys are grouped by provider — set up each account once, grab all its keys together.

# ===== Supabase (one project → URL + 2 keys) =====
# Dashboard → Settings → API : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://...      # [R] Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...      # [R] 'anon' / 'public' key
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # [R] 'service_role' (click Reveal). Server-only, never commit.

# ===== Anthropic ===== https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...              # [R] primary LLM (compliance, estimation, extraction)

# ===== OpenAI ===== https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...                     # [R] embeddings (pgvector KB) + cross-validation

# ===== HuggingFace ===== https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...                # [O] BGE reranking (degrades gracefully if unset)

# ===== Resend ===== https://resend.com/api-keys  (verify a sending domain first)
RESEND_API_KEY=re_...                     # [R] transactional email + Supabase Auth SMTP
RESEND_FROM_EMAIL=noreply@...             # [R] a verified sender on YOUR Resend domain

# ===== Stripe (one account) ===== https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...             # [R] sk_test_ (test) or sk_live_ (live)
# WEBHOOK SECRET is POST-DEPLOY: create the endpoint at https://<your-app-url>/api/webhooks/stripe
# (events: checkout.session.completed, customer.subscription.*) THEN copy its signing secret:
STRIPE_WEBHOOK_SECRET=whsec_...           # [R] from the created webhook endpoint
# Price IDs: Stripe → Products → create a price per module → copy each price_...
STRIPE_COMPLY_PRICE_ID=price_...          # [R]
STRIPE_BUILD_PRICE_ID=price_...           # [R]
STRIPE_QUOTE_PRICE_ID=price_...           # [R]
STRIPE_DIRECT_PRICE_ID=price_...          # [R]
STRIPE_TRAIN_PRICE_ID=price_...           # [R]
STRIPE_BASIC_PRICE_ID=price_...           # [O] legacy bundle
STRIPE_PROFESSIONAL_PRICE_ID=price_...    # [O] legacy bundle

# ===== Inngest ===== https://app.inngest.com  → Manage
INNGEST_SIGNING_KEY=signkey-...           # [R] async jobs (15 functions + cron)
INNGEST_EVENT_KEY=...                     # [R] event ingest

# ===== Mapbox ===== https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk....           # [R] geocoding / maps (site intelligence)
MAPBOX_SECRET_TOKEN=sk....                # [O] server-side, higher limits

# ===== CloudConvert ===== https://cloudconvert.com/dashboard/api/v2/keys
CLOUDCONVERT_API_KEY=...                  # [O] ONLY if you accept DWG / RVT / SKP / DOC plan uploads

# ===== Platform Trust (hosted backend, consumer model) =====
# Required ONLY if ENABLE_SECURITY_GATE=true. Otherwise leave blank and set ENABLE_SECURITY_GATE=false.
PLATFORM_TRUST_SUPABASE_URL=...           # [O]
PLATFORM_TRUST_SERVICE_KEY=...            # [O]
PLATFORM_TRUST_PROJECT_ID=...             # [O]

# ===== ElevenLabs (voice concierge) ===== https://elevenlabs.io/app/agents
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=...       # [O] MMC Direct voice agent (falls back to a test agent)

# ===== Australian Business Register ===== https://abr.business.gov.au/Tools/WebServices
ABR_GUID=...                              # [O] ABN validation in the Direct supplier directory

# ===== HubSpot ===== https://app.hubspot.com/private-apps
HUBSPOT_API_KEY=...                       # [O] CRM sync for directory listings / leads

# ===== HeyGen ===== https://app.heygen.com/settings/api
HEYGEN_API_KEY=...                        # [O] avatar explainer videos for MMC Train

# ===== App config =====
NEXT_PUBLIC_APP_URL=https://...           # [R] deployed URL, e.g. https://app.mmcbuild.com.au (email links, Stripe redirects)
NEXT_PUBLIC_MODULES_LAUNCH_LIST=...       # [O] modules visible to non-admins, e.g. comply,build,quote (unset = all visible)
